<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="#000000"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="Generate Session QR"
            android:textSize="20sp"
            android:textColor="#FF6F00"
            android:textStyle="bold"
            android:layout_marginBottom="12dp"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"/>

        <EditText
            android:id="@+id/etCourse"
            android:hint="Course code (e.g. BIT2206)"
            android:textColor="#000000"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/darker_gray"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etDuration"
            android:hint="Duration (minutes) - default 10"
            android:inputType="number"
            android:textColor="#000000"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/darker_gray"
            android:padding="12dp"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnCreateSession"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Create Session"
            android:backgroundTint="#FF6F00"
            android:textColor="#000000"
            android:layout_marginBottom="12dp"/>

        <!-- 🔥 FIXED QR VIEW -->
        <ImageView
            android:id="@+id/ivQr"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:layout_gravity="center"
            android:layout_marginTop="12dp"
            android:contentDescription="QR code"
            android:background="#FFFFFF"
            android:scaleType="fitCenter"
            android:visibility="visible"/>

        <TextView
            android:id="@+id/tvSessionInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:layout_marginTop="12dp"/>

        <EditText
            android:id="@+id/etSessionId"
            android:hint="(Optional) Session ID to end"
            android:textColor="#000000"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/darker_gray"
            android:padding="12dp"
            android:layout_marginTop="16dp"/>

        <Button
            android:id="@+id/btnEndSession"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="End Session"
            android:backgroundTint="#444444"
            android:textColor="#FFFFFF"
            android:layout_marginTop="8dp"/>

    </LinearLayout>
</ScrollView>